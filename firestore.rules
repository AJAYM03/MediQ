rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isStaff(roleType) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        getRole() == roleType;
    }

    // USERS: Only read own role
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
    }

    // PATIENTS: Null-safe check, staff access
    match /patients/{userId} {
      allow read, write: if isAuthenticated() && (request.auth.uid == userId || isStaff('admin') || isStaff('reception'));
    }

    // QUEUE: The Walk-in and Tamper Fix
    match /today_queue/{tokenId} {
      allow get: if true; 
      allow list: if isStaff('admin') || isStaff('nurse') || isStaff('reception');
      
      // STAFF can create walk-ins. PATIENTS must strictly be remote app users.
      allow create: if isStaff('admin') || isStaff('nurse') || isStaff('reception') ||
                    (isAuthenticated() && 
                     request.resource.data.booking_type == "app" && 
                     request.resource.data.is_physically_present == false &&
                     request.resource.data.patient_uid == request.auth.uid); // Prevents forging someone else's ID
                    
      allow update, delete: if isStaff('admin') || isStaff('nurse') || isStaff('reception');
    }

    // CLINIC STATUS: The Spam Fix
    match /clinic_status/{deskId} {
      allow read: if true;
      
      // Patients can ONLY increment the token by exactly 1, and cannot touch average/pause states.
      allow update: if isAuthenticated() &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['last_issued_token']) &&
                    request.resource.data.last_issued_token == resource.data.last_issued_token + 1;

      allow update: if isStaff('nurse') || isStaff('reception'); 
      allow write: if isStaff('admin'); 
    }

    // CONFIGURATION
    match /departments/{deptId} {
      allow read: if true;
      allow write: if isStaff('admin');
    }
    match /doctors/{docId} {
      allow read: if true;
      allow write: if isStaff('admin');
    }
  }
}